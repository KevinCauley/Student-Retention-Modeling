## 17. Correlation Analysis

```{r correlation-analysis}
cor_data <- student_clean %>%
  transmute(
    FirstPartGrade = FirstPartGradeVisual,
    SecondPartGrade = SecondPartGradeVisual,
    FinalExamGrade = FinalExamGradeVisual,
    FinalGrade = FinalGradeVisual,
    AverageAbsences,
    ScholarshipPercent,
    PastDueBalance = pmin(PastDueBalance, quantile(PastDueBalance, 0.98, na.rm = TRUE)),
    NumAdvisorySessions,
    NumCounselingSessions,
    NumMathTutoringSessions,
    NumFormativePlanSessions,
    CumulativeTeacherEval,
    HonorFaults
  )

cor_matrix <- cor(cor_data, use = "pairwise.complete.obs")

cor_with_outcome <- sort(cor_matrix[, "FinalGrade"], decreasing = TRUE) %>%
  as.data.frame() %>%
  tibble::rownames_to_column("Predictor") %>%
  rename(Correlation = ".") %>%
  filter(Predictor != "FinalGrade") %>%
  mutate(Correlation = round(Correlation, 3))

kable(cor_with_outcome, align = "lr") %>%
  kable_styling(
    full_width = FALSE,
    bootstrap_options = c("striped", "hover", "condensed", "responsive")
  )
```

```{r correlation-heatmap, fig.width=8.5, fig.height=6.2}
cor_plot_data <- as.data.frame(as.table(cor_matrix)) %>%
  rename(Variable_1 = Var1, Variable_2 = Var2, Correlation = Freq)

ggplot(cor_plot_data, aes(x = Variable_1, y = Variable_2, fill = Correlation)) +
  geom_tile(color = "white", linewidth = 0.35) +
  scale_fill_gradient2(
    low = student_red,
    mid = "#F7F9FC",
    high = student_blue,
    midpoint = 0,
    limits = c(-1, 1)
  ) +
  labs(
    title = "Correlation Heatmap of Numeric Variables",
    subtitle = "Correlation analysis helps identify strong predictors and possible multicollinearity before modeling.",
    x = NULL,
    y = NULL,
    fill = "Correlation"
  ) +
  theme_student(11) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1, size = 8.5),
    axis.text.y = element_text(size = 8.5),
    panel.grid = element_blank()
  )
```

