  mutate(
    Percent = n / sum(n),
    Percent = percent(Percent, accuracy = 0.1)
  )

kable(grade_anomaly_summary, align = "lcc") %>%
  kable_styling(
    full_width = FALSE,
    bootstrap_options = c("striped", "hover", "condensed", "responsive")
  )
```

```{r outlier-summary-table}
outlier_summary <- student_clean %>%
  select(all_of(numeric_vars)) %>%
  pivot_longer(
    cols = everything(),
    names_to = "Variable",
    values_to = "Value"
  ) %>%
  group_by(Variable) %>%
  summarise(
    Min = min(Value, na.rm = TRUE),
    Q1 = quantile(Value, 0.25, na.rm = TRUE),
    Median = median(Value, na.rm = TRUE),
    Mean = mean(Value, na.rm = TRUE),
    Q3 = quantile(Value, 0.75, na.rm = TRUE),
    Max = max(Value, na.rm = TRUE),
    IQR = IQR(Value, na.rm = TRUE),
    Lower_Bound = Q1 - 1.5 * IQR,
    Upper_Bound = Q3 + 1.5 * IQR,
    Outlier_Count = sum(Value < Lower_Bound | Value > Upper_Bound, na.rm = TRUE),
    Outlier_Percent = Outlier_Count / n(),
    .groups = "drop"
  ) %>%
  arrange(desc(Outlier_Count))

outlier_display <- outlier_summary %>%
  slice_head(n = 10) %>%
  mutate(
    across(c(Min, Q1, Median, Mean, Q3, Max, Lower_Bound, Upper_Bound), ~ round(.x, 2)),
    Outlier_Percent = percent(Outlier_Percent, accuracy = 0.1)
  ) %>%
  select(
    Variable,
    Min,
    Median,
    Mean,
    Max,
    Outlier_Count,
    Outlier_Percent
  )

kable(outlier_display, align = "lrrrrcc") %>%
  kable_styling(
    full_width = FALSE,
    bootstrap_options = c("striped", "hover", "condensed", "responsive")
  )
```

