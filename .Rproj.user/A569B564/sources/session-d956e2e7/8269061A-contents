```{r 00-merge-datasets, include=FALSE}
hr_df <- data_demographics %>%
  left_join(data_metrics, by = "Employee_ID") %>%
  left_join(data_satisfaction, by = "Employee_ID") %>%
  left_join(data_wellness, by = "Employee_ID") %>%
  left_join(data_monitoring, by = "Employee_ID") %>%
  left_join(data_privacy, by = "Employee_ID") %>%
  left_join(data_attrition, by = "Employee_ID") %>%
  select(
    -Employee_ID,
    -First_Name,
    -Last_Name,
    -Voluntary_Resignation,
    -Involuntary_Termination
  ) %>%
  janitor::clean_names() %>%
  mutate(across(where(is.character), as.factor)) %>%
  mutate(
    across(
      c(turnover_intention, quiet_quitting, monitoring_turnover_risk),
      ~ factor(trimws(as.character(.x)), levels = c("No", "Yes"))
    )
  )

data <- hr_df

dir.create(here("data", "processed"), recursive = TRUE, showWarnings = FALSE)

saveRDS(hr_df, here("data", "processed", "hr_dataset_clean.rds"))
```

