# Safe numeric selector
safe_numeric <- function(df) {
  df %>%
    select(where(is.numeric)) %>%
    select(where(~ var(.x, na.rm = TRUE) > 0)) %>%
    tidyr::drop_na()
}

# Safe factor dummy builder
safe_dummies <- function(df) {
  df %>%
    select(where(is.factor)) %>%
    fastDummies::dummy_cols(
      remove_first_dummy = TRUE,
      remove_selected_columns = TRUE
    ) %>%
    select(where(~ var(.x, na.rm = TRUE) > 0)) %>%
    tidyr::drop_na()
}

# Numeric data frame helper
get_numeric_df <- function(df) {
  df %>%
    select(where(is.numeric)) %>%
    select(where(~ var(.x, na.rm = TRUE) > 0))
}
