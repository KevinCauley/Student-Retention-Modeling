  summarise(across(all_of(likert_vars), ~ var(.x, na.rm = TRUE))) %>%
  pivot_longer(everything(), names_to = "name", values_to = "value") %>%
  arrange(desc(value)) %>%
  slice_head(n = 6) %>%
  pull(name)

top_outliers <- top_likert
