## 17. Correlation Analysis

The correlation review focuses on numeric predictors and their relationship with FinalGrade. The heatmap mutes the diagonal so perfect self-correlations do not dominate the visual.

```{r 17-correlation-summary-table}
cor_vars <- c(
  "FirstPartGrade",
  "SecondPartGrade",
  "FinalExamGrade",
  "FinalGrade",
  "AverageAbsences",
  "ScholarshipPercent",
  "PastDueBalance",
  "NumAdvisorySessions",
  "NumCounselingSessions",
  "NumMathTutoringSessions",
  "NumFormativePlanSessions",
  "CumulativeTeacherEval",
  "HonorFaults"
)

cor_data <- student_clean %>%
  select(any_of(cor_vars)) %>%
  drop_na()

cor_matrix <- cor(cor_data, use = "pairwise.complete.obs")

final_grade_correlations <- as.data.frame(cor_matrix) %>%
  rownames_to_column("Predictor") %>%
  select(Predictor, Correlation = FinalGrade) %>%
  filter(Predictor != "FinalGrade") %>%
  arrange(desc(abs(Correlation))) %>%
  mutate(
    Correlation = number(Correlation, accuracy = 0.001)
  )

kable(final_grade_correlations, align = "lr") %>%
  kable_styling(
    full_width = FALSE,
    bootstrap_options = c("striped", "hover", "condensed", "responsive")
  )
```

```{r 17-correlation-heatmap, fig.width=7.2, fig.height=5.0, out.width="82%"}
cor_long <- as.data.frame(cor_matrix) %>%
  rownames_to_column("Var1") %>%
  pivot_longer(
    cols = -Var1,
    names_to = "Var2",
    values_to = "Correlation"
  ) %>%
  mutate(
    Var1 = factor(Var1, levels = rev(cor_vars)),
    Var2 = factor(Var2, levels = cor_vars),
    Diagonal = as.character(Var1) == as.character(Var2),
    Correlation_Display = if_else(Diagonal, NA_real_, Correlation)
  )

p <- ggplot(cor_long, aes(x = Var2, y = Var1, fill = Correlation_Display)) +
  geom_tile(color = "white", linewidth = 0.25) +
  scale_fill_gradient2(
    low = student_red,
    mid = "#F8FAFC",
    high = student_blue,
    midpoint = 0,
    limits = c(-1, 1),
    na.value = "#EDF2F7"
  ) +
  labs(
    title = "Correlation Heatmap of Numeric Variables",
    subtitle = wrap_text("The diagonal is muted because each variable is perfectly correlated with itself."),
    x = NULL,
    y = NULL,
    fill = "Correlation"
  ) +
  theme_student(9.4) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    panel.grid = element_blank()
  )

print(p)

save_plot(
  p,
  "correlation_heatmap_numeric_variables.png",
  width = 9.2,
  height = 6.4
)
```

